                              <TextRuns>
                                <TextRun>
                                  <Value EvaluationMode="Auto">=iif(Fields!SaldoaFecha.Value&lt;0,Sum(Fields!DebitAmount_GLEntry.Value),Sum(Fields!DebitAmount_GLEntry.Value)+(Fields!SaldoaFecha.Value))</Value>
